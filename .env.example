# =============================================================================
# 環境変数リファレンス
# =============================================================================
# アプリは起動時にカレントディレクトリの .env を読む（godotenv）。
#
# ローカル開発:
#   cp .env.example .env して必要な値を書き換える。
#
# 本番:
#   .env は使わない。別リポジトリ nz-vps-ops (Ansible + systemd + Caddy) の
#   apps/<公開ホスト名>.yml の app_env_vars で設定する。
#   各変数の意味・デフォルト値はこのファイルが正（コードと一緒に保守する）。
#   コードで os.Getenv する変数は必ずここに記載する（make check-env-docs で検証）。
#
# Litestream (R2 バックアップ) の設定・認証情報は nz-vps-ops 側で管理する
# （roles/litestream + vault）ため、このファイルには含めない。
# =============================================================================

# =============================================================================
# ローカル開発の基本
# =============================================================================

# 環境識別。「dev」のときだけ開発モードになる。未設定やその他の値は
# すべて本番扱い（設定し忘れても安全側）。dev の場合:
#   - SERVER_ADDR が http:// のとき、セッション Cookie の Secure 属性が false になる
#     （http://localhost でログインが機能するために必要）
#   - /datastar-test の開発用テストページが公開される
#   - SERVER_ADDR 未設定時に http://localhost:<PORT> を自動解決する
APP_ENV=dev

# 初回起動時の自動管理者作成に使用するメアド。
# DB にユーザーが存在する場合は無視される。
# 未設定時は管理者自動作成がスキップされる（手動で DB に追加、
# または /setup ページで作成する必要がある）。
ADMIN_EMAIL=you@example.com

# 自動管理者作成時の名前。
# デフォルト: Admin
ADMIN_NAME="Your Name"

# =============================================================================
# 本番で必須
# =============================================================================
# ローカル開発では未設定のままでよい。

# サーバーアドレス (例: https://example.com)。以下の機能に使用される:
#   - WebAuthn の RP ID / 許可オリジン（オリジン検証に使用）
#   - マジックリンクのメールに含まれる URL の生成
# dev では未設定で http://localhost:<PORT> を自動解決する。
# 本番では未設定だとビルド時に埋め込まれた値（Makefile の SERVER_ADDR、
# デフォルト http://localhost:8080）にフォールバックするため、必ず明示すること。
# SERVER_ADDR=https://example.com

# パスキー登録時にユーザーに表示されるアプリ名。
# 未設定時は "Project CRUD" がハードコードされたデフォルト値になる。
# WEBAUTHN_RP_NAME="Your App Name"

# SMTP 設定 — マジックリンクのメール送信用。
# 本番で未設定だとメール送信に失敗し、ログインが機能しない。
# ローカル開発では .bypass_emails（1行1メールアドレス）に書いたアドレスは
# メール送信されずログイン用リンクがレスポンスで返るため、SMTP なしで動かせる。
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME="Your App Name"

# =============================================================================
# オプション（デフォルトあり）
# =============================================================================
# 未設定時はアプリが既定値で動作する。

# リッスンポート。
# デフォルト: 8080
# PORT=8080

# データベースファイルパス（SQLite）。
# デフォルト: app.db（カレントディレクトリ）
# DB_PATH=app.db

# ログファイルの出力ディレクトリ。
# 未設定時は標準出力 / 標準エラー出力にログが出力される（ファイル書き込みなし。
# 本番は systemd の journal に乗るためこれで足りる）。
# 設定した場合は access.log と app.log が lumberjack でローテーションされる
# (最大 100MB / ファイル、3世代保持、28日、gzip圧縮)。
# LOG_DIR=

# =============================================================================
# テスト専用
# =============================================================================

# レート制限を無効化。負荷テスト時のみ true に設定すること。
# 通常は未設定（= レート制限有効）のままであること。
# DISABLE_RATE_LIMITING=true
