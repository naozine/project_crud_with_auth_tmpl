# =============================================================================
# .env.production - 本番環境変数テンプレート
# =============================================================================
# このファイルをコピーして .env.production を作成してください:
#   cp .env.production.example .env.production
#
# fly.io への反映:
#   make -f fly.mk fly-secrets
# =============================================================================

# --- SMTP設定 ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@example.com"
SMTP_FROM_NAME="Your App Name"

# --- 管理者設定 ---
ADMIN_EMAIL="admin@example.com"

# --- Litestream (Cloudflare R2 バックアップ) ---
# プロジェクトごとにバケットと API トークンを分けること（セキュリティ分離）
# R2 ダッシュボード → API トークンを管理 → バケット単位でスコープを絞って発行
LITESTREAM_ACCESS_KEY_ID=""
LITESTREAM_SECRET_ACCESS_KEY=""
LITESTREAM_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# 未設定時は <プロジェクト名>-litestream がデフォルト
#LITESTREAM_BUCKET=
